BOYNTON_DATABASE_URL=postgresql:///boynton_bot
BOYNTON_MEMORY_DIR=/path/to/memory

# For OpenAI only:
BOYNTON_OPENAI_API_KEY=sk-...
BOYNTON_LLM_MODEL=gpt-5.4-mini

# For local qwen (or any OpenAI-compatible server):
# BOYNTON_OPENAI_API_KEY=local
# BOYNTON_LLM_BASE_URL=http://localhost:8000/v1
# BOYNTON_LLM_MODEL=qwen3-8b

# For local qwen with OpenAI fallback (positionally matched, tried in order):
# BOYNTON_OPENAI_API_KEY=local,sk-...
# BOYNTON_LLM_BASE_URL=http://localhost:8000/v1,https://api.openai.com/v1
# BOYNTON_LLM_MODEL=qwen3-8b,gpt-5.4-mini

# Email (optional — required for send_email tool):
# BOYNTON_EMAIL_ADDRESS=you@example.com
# BOYNTON_EMAIL_PASSWORD=...
# BOYNTON_EMAIL_SMTP_HOST=smtp.hostinger.com
# BOYNTON_EMAIL_SMTP_PORT=465
# BOYNTON_EMAIL_RECIPIENT=you@example.com
